def main():
    """Entry point — main menu loop."""
    clear_screen()
    display_banner()

    print("\n  Welcome to the Python Quiz Game! 🐍")
    player_name = input("\n  Enter your name: ").strip()
    if not player_name:
        player_name = "Player"

    while True:
        clear_screen()
        display_banner()
        print(f"\n  Hello, {player_name}! 👋\n")
        print("    1. 🎮  Start Quiz")
        print("    2. 🏆  View Leaderboard")
        print("    3. 📋  View Categories")
        print("    4. 🚪  Exit")

        choice = get_valid_input("\n  Choose an option: ", ["1", "2", "3", "4"])

        if choice == "1":
            run_quiz(player_name)
            input("\n  Press Enter to return to menu...")

        elif choice == "2":
            clear_screen()
            display_banner()
            display_leaderboard()
            input("\n  Press Enter to return to menu...")

        elif choice == "3":
            clear_screen()
            display_banner()
            print("\n  📚 AVAILABLE CATEGORIES & TOPICS:\n")
            for cat, qs in QUESTIONS.items():
                print(f"  📂 {cat} ({len(qs)} questions)")
                for q in qs:
                    print(f"      • {q['question'][:55]}...")
                print()
            input("  Press Enter to return to menu...")

        elif choice == "4":
            clear_screen()
            display_banner()
            print(f"\n  Thanks for playing, {player_name}! 👋")
            print("  ⭐ Don't forget to star the GitHub repo!\n")
            break


if __name__ == "__main__":
    main()
