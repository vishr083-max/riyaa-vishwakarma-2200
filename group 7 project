LEADERBOARD_FILE = "leaderboard.json"


# ─────────────────────────────────────────────
#  UTILITY FUNCTIONS
# ─────────────────────────────────────────────

def clear_screen():
    """Clear the terminal screen."""
    os.system('cls' if os.name == 'nt' else 'clear')


def display_banner():
    """Display the game banner."""
    print("\n" + "═" * 55)
    print("        🎯  PYTHON QUIZ GAME  🎯")
    print("           Group Project - GitHub")
    print("═" * 55)


def display_separator():
    print("─" * 55)


def get_valid_input(prompt, valid_options):
    """Get validated input from the user."""
    while True:
        user_input = input(prompt).strip().upper()
        if user_input in valid_options:
            return user_input
        print(f"  ❌ Invalid input. Please choose from: {', '.join(valid_options)}")


def load_leaderboard():
    """Load leaderboard from JSON file."""
    if os.path.exists(LEADERBOARD_FILE):
        try:
            with open(LEADERBOARD_FILE, "r") as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            return []
    return []


def save_leaderboard(leaderboard):
    """Save leaderboard to JSON file."""
    try:
        with open(LEADERBOARD_FILE, "w") as f:
            json.dump(leaderboard, f, indent=4)
    except IOError:
        print("  ⚠️  Could not save leaderboard.")


def display_leaderboard():
    """Display the top 10 leaderboard."""
    leaderboard = load_leaderboard()
    display_separator()
    print("  🏆  TOP 10 LEADERBOARD")
    display_separator()
    if not leaderboard:
        print("  No scores yet. Be the first to play!")
    else:
        sorted_lb = sorted(leaderboard, key=lambda x: x["score"], reverse=True)[:10]
        for i, entry in enumerate(sorted_lb, 1):
            medal = ["🥇", "🥈", "🥉"][i - 1] if i <= 3 else f"  {i}."
            print(f"  {medal} {entry['name']:<15} {entry['score']:>3} pts  |  {entry['category']:<15} |  {entry['date']}")
    display_separator()


# ─────────────────────────────────────────────
#  CORE GAME LOGIC
# ─────────────────────────────────────────────

def select_category():
    """Let player choose a quiz category."""
    categories = list(QUESTIONS.keys())
    print("\n  📚 SELECT A CATEGORY:\n")
    for i, cat in enumerate(categories, 1):
        print(f"    {i}. {cat}")
    print(f"    {len(categories)+1}. 🎲 Random Mix")

    valid = [str(i) for i in range(1, len(categories) + 2)]
    choice = get_valid_input("\n  Enter number: ", valid)
    choice = int(choice)

    if choice == len(categories) + 1:
        return "Random Mix"
    return categories[choice - 1]


def select_difficulty():
    """Select number of questions (acts as difficulty)."""
    print("\n  ⚙️  SELECT DIFFICULTY:\n")
    print("    1. Easy   (5 questions)")
    print("    2. Medium (10 questions)")
    print("    3. Hard   (15 questions)")

    choice = get_valid_input("\n  Enter number: ", ["1", "2", "3"])
    return {"1": 5, "2": 10, "3": 15}[choice]


def get_questions(category, num_questions):
    """Fetch and shuffle questions."""
    if category == "Random Mix":
        all_q = []
        for q_list in QUESTIONS.values():
            all_q.extend(q_list)
        pool = all_q
    else:
        pool = QUESTIONS[category]

    shuffled = pool.copy()
    random.shuffle(shuffled)
    return shuffled[:min(num_questions, len(shuffled))]


def ask_question(question_data, q_num, total):
    """Display a question and get the player's answer."""
    print(f"\n  Question {q_num}/{total}")
    display_separator()
    print(f"  {question_data['question']}\n")
    for option in question_data["options"]:
        print(f"    {option}")
    display_separator()

    start_time = time.time()
    answer = get_valid_input("  Your answer (A/B/C/D): ", ["A", "B", "C", "D"])
    elapsed = round(time.time() - start_time, 2)

    correct = answer == question_data["answer"]

    if correct:
        print(f"\n  ✅  Correct! ({elapsed}s)")
    else:
        print(f"\n  ❌  Wrong! Correct answer: {question_data['answer']}")

    print(f"  💡  {question_data['explanation']}")
    time.sleep(1.5)
    return correct, elapsed


def calculate_score(correct, total, time_taken):
    """Calculate score with time bonus."""
    base_score = (correct / total) * 100
    time_bonus = max(0, 50 - int(time_taken / total))
    return int(base_score + time_bonus)


def run_quiz(player_name):
    """Main quiz runner."""
    clear_screen()
    display_banner()

    category = select_category()
    num_questions = select_difficulty()
    questions = get_questions(category, num_questions)

    clear_screen()
    display_banner()
    print(f"\n  👤 Player  : {player_name}")
    print(f"  📂 Category: {category}")
    print(f"  ❓ Questions: {len(questions)}")
    print("\n  Get ready...", end="", flush=True)
    time.sleep(2)
    print(" GO! 🚀")
    time.sleep(0.5)

    correct_count = 0
    total_time = 0

    for i, q in enumerate(questions, 1):
        clear_screen()
        display_banner()
        is_correct, elapsed = ask_question(q, i, len(questions))
        if is_correct:
            correct_count += 1
        total_time += elapsed

    # ── Results ──
    clear_screen()
    display_banner()
    score = calculate_score(correct_count, len(questions), total_time)

    print(f"\n  🎉 QUIZ COMPLETE!\n")
    display_separator()
    print(f"  Player    : {player_name}")
    print(f"  Category  : {category}")
    print(f"  Score     : {correct_count} / {len(questions)} correct")
    print(f"  Total Time: {round(total_time, 1)}s")
    print(f"  Points    : {score} 🏅")
    display_separator()

    if score >= 90:
        print("  🌟 OUTSTANDING! You're a genius!")
    elif score >= 70:
        print("  👏 GREAT JOB! Well done!")
    elif score >= 50:
        print("  👍 Not bad! Keep practicing.")
    else:
        print("  📖 Keep studying. You'll get better!")

    # Save to leaderboard
    leaderboard = load_leaderboard()
    leaderboard.append({
        "name": player_name,
        "score": score,
        "correct": correct_count,
        "total": len(questions),
        "category": category,
        "date": datetime.now().strftime("%Y-%m-%d")
    })
    save_leaderboard(leaderboard)
    print("\n  ✅ Score saved to leaderboard!")

    return score


